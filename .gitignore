# Session handoffs — local only, not published
Handoff/

# Design/code reviews — local working notes, not published
reviews/

# Instructor-provided assignment materials
*.docx
# Per-homework task/materials folders — local only, never published
hw*/task/
final_project/task/

# Large model checkpoints (results are captured in the notebooks/JSON)
*.pt
*.pth
*.onnx
# Small deterministic ONNX fixtures are part of the test suite and must ship.
!final_project/tests/fixtures/**/*.onnx
!final_project/cpp/tests/fixtures/**/*.onnx

# Datasets.
# Anchored on purpose: a bare `data/` also matches src/wildlife_trigger/data/,
# configs/data/ and data/manifests/, all of which DESIGN §14 requires committed.
/final_project/data/raw/
/final_project/data/images/
/final_project/data/interim/
/final_project/data/cache/
/hw*/data/

# Environments.
# Deliberately not a bare `env/`: that matches a directory named env at ANY
# depth, which silently swallowed configs/env/ and its pinned version manifests.
# Same class of bug as the old bare `data/` rule — see tests/python for the guard
# that now catches it.
venv/
.venv/
/env/

# Python caches
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.pytest_cache/
*.egg-info/
.ruff_cache/

# C++ build outputs
build/
cmake-build-*/
compile_commands.json

# Temporary benchmark output
*.perf
onnxruntime_profile_*.json

# Key material. Public keys are safe to share, but they are still clutter in a
# public repo — and the broader patterns stop a private key from ever being
# swept up by `git add -A`.
*.pub
*.pem
id_ed25519*
id_rsa*

# A dotfile .env conventionally holds credentials. Note this is NOT `*.env`:
# configs/env/pins.env is shell-sourceable version pins with no secrets in it,
# and it must be committed — the Dockerfile and setup scripts read it.
.env
.env.*

# OS / editor
.DS_Store
.idea/
.vscode/
