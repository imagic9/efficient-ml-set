# Session handoffs — local only, not published
Handoff/

# Design/code reviews — local working notes, not published
reviews/

# Instructor-provided assignment materials
*.docx
# Per-homework task/materials folders — local only, never published
hw*/task/
final_project/task/

# Large model checkpoints (results are captured in the notebooks/JSON)
*.pt
*.pth
*.onnx
# Small deterministic ONNX fixtures are part of the test suite and must ship.
!final_project/tests/fixtures/**/*.onnx
!final_project/cpp/tests/fixtures/**/*.onnx

# Datasets.
# Anchored on purpose: a bare `data/` also matches src/wildlife_trigger/data/,
# configs/data/ and data/manifests/, all of which DESIGN §14 requires committed.
/final_project/data/raw/
/final_project/data/images/
/final_project/data/interim/
/final_project/data/cache/
/hw*/data/

# Environments.
# Deliberately not a bare `env/`: that matches a directory named env at ANY
# depth, which silently swallowed configs/env/ and its pinned version manifests.
# Same class of bug as the old bare `data/` rule — see tests/python for the guard
# that now catches it.
venv/
.venv/
/env/

# Python caches
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.pytest_cache/
*.egg-info/
.ruff_cache/

# C++ build outputs
build/
cmake-build-*/
compile_commands.json

# Temporary benchmark output
*.perf
onnxruntime_profile_*.json

# The per-image dimension index is a build intermediate: B0 writes it so B1 can
# attach observed geometry without a second pass over 57,864 files, and once the
# manifests carry observed_width/height per image it is redundant. The report that
# matters — the distribution and DESIGN §5.5's checks — is committed under
# results/data_audit/.
/final_project/data/manifests/dimensions.json

# Staged deployment bundles. A bundle is a build output — binary, libonnxruntime.so,
# model — rebuilt by scripts/build_bundle.sh in the target container, ~20 MB, and
# reproducible. What must be committed is the audit that describes it
# (evidence/bundle_audit.json records the file list, checksums and GLIBC ceiling),
# not the bytes.
/final_project/results/**/bundle/

# Raw tensor blobs: fixtures and model outputs under results/. Every one is
# reproducible — the fixture from its recorded seed, the outputs by re-running the
# probe — and each is ~600 KB of noise. What must be committed is their identity,
# not their bytes: validate.fixture writes shape/seed/SHA-256 to input_fixture.json
# beside them, so a later run can prove it read the same input.
/final_project/results/**/*.bin

# C4 parity intermediates (dump-tensor .bin/.json pairs, ort_probe logits and
# scratch, raw infer JSONs). Reproducible by scripts/run_c4_parity.sh; the
# committed evidence is the comparators' p1_preprocess.json / p_ort_cpp.json,
# which embed every geometry, error stat and decision.
/final_project/results/parity/*/p1/
/final_project/results/parity/*/ort/

# D1 P3/P4 intermediates (ort_probe logits/scratch, raw infer JSONs, per-frame
# run-dataset JSONL, the P3 re-evaluation). Reproducible by
# scripts/run_d1_p3p4.sh; the committed evidence is p3_quantized.json /
# p4_dataset_parity.json, which embed every gap, decision and verdict.
/final_project/results/optimize/*/*/p3/
/final_project/results/optimize/*/*/p4/
/final_project/results/optimize/*/*/p3_reevaluation/
/final_project/results/optimize/*/*/p3_coverage/

# E1 foundation: the stratified slice and the per-frame run-dataset predictions
# are large and reproducible by scripts/run_e1_foundation.sh. The committed
# evidence is e1_gate.json plus the small per-command JSONs and stderr captures.
/final_project/results/e1/evidence/e1_slice.jsonl
/final_project/results/e1/evidence/run_dataset.m0.jsonl

# E4 dataset-runner parity: the per-frame validation JSONL is large and
# reproducible by scripts/run_e4_m0_parity.sh. The committed evidence is
# p4_dataset_parity_m0.json.
/final_project/results/e4/cpp_cis_val_clean.jsonl
/final_project/results/e4/cpp_trans_val.jsonl

# E6 pre-rental QEMU parity: the slice and the per-frame native/qemu predictions are
# reproducible by scripts/run_e6_qemu_parity.sh. The committed evidence is
# qemu_parity.json.
/final_project/results/e6/e6_slice.jsonl
/final_project/results/e6/native_*.jsonl
/final_project/results/e6/qemu_*.jsonl

# E6 optimization matrix + reduced-decode drift: the per-cell benchmark JSONs and the
# per-model run-dataset JSONL are bulky and reproducible by
# scripts/run_e6_optimization_matrix.sh and scripts/run_e6_decode_drift.sh. The
# committed evidence is optimization_matrix.json and decode_drift.json.
/final_project/results/e6/optimization_matrix/
/final_project/results/e6/decode_drift/

# Key material. Public keys are safe to share, but they are still clutter in a
# public repo — and the broader patterns stop a private key from ever being
# swept up by `git add -A`.
*.pub
*.pem
id_ed25519*
id_rsa*

# A dotfile .env conventionally holds credentials. Note this is NOT `*.env`:
# configs/env/pins.env is shell-sourceable version pins with no secrets in it,
# and it must be committed — the Dockerfile and setup scripts read it.
.env
.env.*

# OS / editor
.DS_Store
.idea/
.vscode/

# codebase-memory MCP's index cache. Machine-generated, rebuildable from the source in
# one command, and stale the moment anything is committed — the artifact that used to
# live here described 1,131 nodes at a commit from before final_project existed, while
# the real index holds 3,897. A cache that disagrees with the code it indexes is worse
# than no cache: it answers questions confidently about a repository that is gone.
.codebase-memory/

# E6 native-vs-target: per-toolchain run-dataset/self-test are reproducible by
# scripts/run_e6_native_vs_target.sh. The committed evidence is native_vs_target.json.
/final_project/results/e6/native_vs_target/

# E6 gate: the retained ALL/EXTENDED optimized graphs + profiles are bulky and
# reproducible by scripts/run_e6_gate.sh. The committed evidence is e6_gate.json.
/final_project/results/e6/graphs/
