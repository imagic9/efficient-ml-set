# Pinned dependency versions — single source of truth.
#
# Shell-sourceable so scripts and Dockerfile build-args cannot drift apart.
# DESIGN §9.2 requires every run to record what it resolved to; this file records
# what it was *asked* to resolve to. Both are kept.
#
# Do not bump a pin without re-running the gate that justified it.

# ---------------------------------------------------------------------------
# Target-compatible ARM64 container
# ---------------------------------------------------------------------------
# Bookworm because Raspberry Pi OS Bookworm ships glibc 2.36, while gx10 runs
# Ubuntu 24.04 with 2.39. A binary linked against 2.36 still loads on a newer Pi
# OS (Trixie, 2.41); the reverse fails outright. Building against the OLDEST
# plausible target is the only choice that covers both.
TARGET_BASE_IMAGE="debian:bookworm-slim"
TARGET_BASE_DIGEST="sha256:7b140f374b289a7c2befc338f42ebe6441b7ea838a042bbd5acbfca6ec875818"
TARGET_GLIBC="2.36"
TARGET_IMAGE_TAG="wildlife-trigger-target:bookworm"

# ---------------------------------------------------------------------------
# ONNX Runtime — the official prebuilt aarch64 CPU tarball
# ---------------------------------------------------------------------------
# Measured on 2026-07-15: the aarch64 libonnxruntime.so requires at most
# GLIBC_2.27 and GLIBCXX_3.4.21, far below bookworm's 2.36, and links only against
# standard system libraries. So one identical ORT binary runs in the gx10
# container and on the Pi, which removes ORT from the compatibility risk surface
# entirely. Re-verify on any bump — that is a property of their build, not a
# promise.
#
# 1.27.0, not the newer 1.27.1, because PyPI publishes no 1.27.1 wheel and P3
# requires ORT Python and ORT C++ to produce identical predictions on fixtures.
# With a version split, P3 would be measuring the gap between two ORT releases
# instead of the gap between our two call sites. Matching versions is worth more
# than one patch release.
#
# SHA-256 independently cross-checked against the digest GitHub publishes for the
# release asset.
ORT_VERSION="1.27.0"
ORT_SHA256="3e4d83ac06924a32a07b6d7f91ce6f852876153fc0bbdf931bf517a140bfbe48"
ORT_URL="https://github.com/microsoft/onnxruntime/releases/download/v${ORT_VERSION}/onnxruntime-linux-aarch64-${ORT_VERSION}.tgz"
ORT_PREFIX="/opt/onnxruntime"

# ---------------------------------------------------------------------------
# OpenCV — a known, deliberate, measured gap
# ---------------------------------------------------------------------------
# C++ uses bookworm's apt OpenCV 4.6.0, because that is what the Pi can have.
# Python uses the newest 4.x wheel. They are NOT identical, and that is a real
# risk to P1: the only preprocessing step whose implementation could differ
# between versions is the INTER_LINEAR resize (decode, BGR->RGB, pad, scale and
# normalise are all trivially defined).
#
# The default pip resolution was opencv-python 5.0.0 — a major-version gap, which
# would have made P1 measure "OpenCV 5 vs OpenCV 4" rather than "our Python vs our
# C++". Pinning to 4.x removes that. The remaining 4.6-vs-4.13 gap is left in
# place deliberately: P1 quantifies it against golden fixtures, and if the drift
# exceeds tolerance the answer is to build a matching OpenCV from source in the
# container and bundle those .so to the Pi. Measure first, then decide.
OPENCV_PYTHON_VERSION="4.13.0.92"
OPENCV_CPP_VERSION="4.6.0"  # from bookworm apt; informational, set by the distro

# ---------------------------------------------------------------------------
# Training environment on gx10
# ---------------------------------------------------------------------------
# torch 2.11.0+cu130 is pinned because A0 verified it on this exact GPU: GB10,
# compute capability 12.1, driver 580.142, CUDA 13.0. Newer exists; known-working
# on Blackwell beats newest.
#
# The venv lives outside the repository and outside ~/efficientml/venv, which has
# include-system-site-packages=true and therefore inherits ~5 GB of unrelated
# packages from ~/.local. A lockfile taken from that environment would describe
# something we do not control.
PYTHON_BIN="python3.12"
VENV_PATH="${HOME}/venvs/wildlife_trigger"
TORCH_VERSION="2.11.0"
TORCHVISION_VERSION="0.26.0"
TORCH_INDEX_URL="https://download.pytorch.org/whl/cu130"

# ---------------------------------------------------------------------------
# ISA emulation (issue #9)
# ---------------------------------------------------------------------------
# Reproduces the Pi's HWCAP so ORT dispatches the Pi's kernels. Correctness
# evidence only — QEMU models no caches or memory bandwidth, so no emulated
# timing is ever a result.
QEMU_PI5_CPU="cortex-a76"
QEMU_PI4_CPU="cortex-a72"
